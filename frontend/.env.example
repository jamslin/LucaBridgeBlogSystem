# Base URL of the Spring Boot API, used by SSR loaders (server-side only,
# never exposed to the browser). In Docker Compose this is http://backend:8080.
API_URL=http://localhost:8080

# Public origin of the site, used for absolute og:image / canonical URLs.
# In prod set to the real domain, e.g. https://lucabridge.org
SITE_ORIGIN=http://localhost:3000
